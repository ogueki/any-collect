# =========================================================
#  サーバ側のみ（Vercel Functions）。クライアントには絶対に出さない。
# =========================================================
GEMINI_API_KEY=
# モデル上書きは任意（未指定なら既定: テキスト=gemini-2.5-flash / 画像=gemini-2.5-flash-image）
GEMINI_TEXT_MODEL=
GEMINI_IMAGE_MODEL=
# ANTHROPIC_API_KEY は将来 Claude で会話する場合のみ必要（初期は Gemini で会話するため任意）
ANTHROPIC_API_KEY=
FISH_AUDIO_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- 画像生成プロバイダ切替（スキャン高速化の検証用・任意） ---
# 既定は Gemini。'fal' にすると撮影アイテム化の画像生成だけ fal の高速モデルに差し替わる
# （メタ生成は常に Gemini）。未設定/gemini なら現行どおり＝完全可逆。
IMAGE_PROVIDER=
# IMAGE_PROVIDER=fal のときのみ必須
FAL_KEY=
# 任意。未指定なら高速 img2img の既定（fal-ai/fast-sdxl/image-to-image）。
# 忠実度寄りにしたいときは FLUX Kontext 等のモデル ID を指定して A/B 可能。
FAL_IMAGE_MODEL=
# 任意。img2img の効き具合 0〜1（既定 0.6／小さいほど元写真に忠実）。
FAL_IMG2IMG_STRENGTH=

# =========================================================
#  クライアント公開用（VITE_ プレフィックスはバンドルに含まれる＝公開前提の値のみ）
# =========================================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
